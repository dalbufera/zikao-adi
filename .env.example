# ZIKAO Configuration - Être Humain Numérique / DJ

# OpenRouter (Claude AI)
OPENROUTER_KEY=your_openrouter_key

# OpenAI TTS (Voice)
OPENAI_KEY=your_openai_key
OPENAI_VOICE=onyx

# Suno AI (Singing) via APIPASS
APIPASS_KEY=your_apipass_key

# ACRCloud (Music Recognition)
ACRCLOUD_HOST=identify-eu-west-1.acrcloud.com
ACRCLOUD_KEY=your_acrcloud_key
ACRCLOUD_SECRET=your_acrcloud_secret

# AudD (Music Recognition - alternative)
AUDD_KEY=your_audd_key

# YouTube Data API
YOUTUBE_API_KEY=your_youtube_api_key

# Server
PORT=3100
